{
  "name": "@mlxts/align",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "keywords": [
    "mlxts",
    "alignment",
    "sft",
    "dpo",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.4"
  },
  "dependencies": {
    "@mlxts/core": "workspace:*",
    "@mlxts/data": "workspace:*",
    "@mlxts/lora": "workspace:*",
    "@mlxts/nn": "workspace:*",
    "@mlxts/tokenizers": "workspace:*",
    "@mlxts/train": "workspace:*",
    "@mlxts/transformers": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "build": "bun run ../../scripts/build-package.ts --entry src/index.ts"
  }
}
