{
  "name": "@mlxts/transformers",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "keywords": [
    "mlxts",
    "transformers",
    "llm",
    "mlx",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.4"
  },
  "dependencies": {
    "@huggingface/hub": "^2.11.0",
    "@huggingface/jinja": "^0.5.6",
    "@mlxts/core": "workspace:*",
    "@mlxts/lora": "workspace:*",
    "@mlxts/nn": "workspace:*",
    "@mlxts/quantize": "workspace:*",
    "@mlxts/tokenizers": "workspace:*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "build": "bun run ../../scripts/build-package.ts --entry src/index.ts",
    "parity:verify": "bun run scripts/verify-llama-parity.ts",
    "bench:cache": "bun run scripts/benchmark-cache.ts",
    "regression:models": "bun run scripts/regression-model-matrix.ts"
  }
}
