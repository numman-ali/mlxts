{
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@mlxts/core": ["packages/core/src/index.ts"],
      "@mlxts/nn": ["packages/nn/src/index.ts"],
      "@mlxts/optimizers": ["packages/optimizers/src/index.ts"],
      "@mlxts/train": ["packages/train/src/index.ts"],
      "@mlxts/train/supervised-run": ["packages/train/src/supervised-run/index.ts"],
      "@mlxts/data": ["packages/data/src/index.ts"],
      "@mlxts/quantize": ["packages/quantize/src/index.ts"],
      "@mlxts/lora": ["packages/lora/src/index.ts"],
      "@mlxts/align": ["packages/align/src/index.ts"],
      "@mlxts/agent": ["packages/agent/src/index.ts"],
      "@mlxts/protocols": ["packages/protocols/src/index.ts"],
      "@mlxts/serve": ["packages/serve/src/index.ts"],
      "@mlxts/tokenizers": ["packages/tokenizers/src/index.ts"],
      "@mlxts/transformers": ["packages/transformers/src/index.ts"]
    },
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "verbatimModuleSyntax": true,
    "types": ["bun"]
  },
  "exclude": ["node_modules", "dist", "build"]
}
