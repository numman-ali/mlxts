{
  "name": "mlxts",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/nanogpt"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun run --filter '*' test",
    "test:coverage": "bun run --filter '*' test:coverage",
    "build": "bun run scripts/build-workspaces.ts",
    "build:native": "bun run --filter '@mlxts/core' build:native",
    "check:assertions": "bun run scripts/check-type-assertions.ts",
    "check:file-lines": "bun run scripts/check-file-lines.ts",
    "check:per-package-agents": "bun run scripts/check-per-package-agents.ts",
    "check:cross-package-imports": "bun run scripts/check-cross-package-imports.ts",
    "check:training-proofs": "tsc -p tsconfig.phase8-examples.json && bun test examples/train-proof/helpers.test.ts examples/train-proof/verification.test.ts examples/lora-finetune/helpers.test.ts",
    "proof:training": "bun run examples/train-proof/index.ts",
    "check:tensor-lifetimes": "bun run scripts/check-visible-tensor-lifetimes.ts",
    "check:runtime-review": "bun run scripts/check-runtime-review.ts",
    "check:coverage": "bun run scripts/check-coverage.ts",
    "bench:generation": "bun run packages/transformers/scripts/benchmark-generation.ts",
    "bench:generation:parity": "bun run packages/transformers/scripts/benchmark-generation-parity.ts",
    "bench:generation:context": "bun run packages/transformers/scripts/benchmark-long-context.ts",
    "bench:serve": "bun run packages/serve/scripts/benchmark-serve.ts",
    "regression:qwen-gemma": "bun run scripts/regression-qwen-gemma.ts",
    "regression:qwen-image": "bun run packages/serve/scripts/regression-qwen-image.ts",
    "validate": "bun run typecheck && bun run lint && bun run check:assertions && bun run check:file-lines && bun run check:per-package-agents && bun run check:cross-package-imports && bun run check:training-proofs && bun run check:tensor-lifetimes && bun run check:runtime-review && bun run check:coverage",
    "docs:api": "typedoc",
    "pack:dry-run": "bun run scripts/pack-public-packages.ts",
    "release:check": "bun run validate && bun run build && bun run docs:api && bun run pack:dry-run",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "prepare": "bun run .hooks/install.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.4",
    "typedoc": "^0.28.14",
    "typescript": "^6.0.2"
  }
}
