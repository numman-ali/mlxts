#!/usr/bin/env bash
# Pre-commit hook: runs the full validation pipeline
# Tied to the project's quality gates — lint, typecheck, assertions, and coverage-backed tests
#
# This hook enforces the "validate before commit" step of the agentic loop.
# See docs/agentic-loop.md for context.

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BOLD='\033[1m'
NC='\033[0m'

echo ""
echo -e "${BOLD}nanogpt-ts pre-commit validation${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

echo -e "\n${BOLD}[1/1]${NC} Running full validation..."
if bun run validate; then
  echo -e "${GREEN}${BOLD}All checks passed.${NC} Committing."
  exit 0
fi

echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "${RED}${BOLD}Commit blocked.${NC} Fix the issues above and try again."
echo -e "${YELLOW}Tip:${NC} Run 'bun run validate' to check everything locally."
exit 1
